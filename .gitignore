# dependencies
node_modules/

# build output / artifacts
dist/
build/
target/
contracts/wasms/
test_snapshots/
*.tsbuildinfo

# indexer runtime cache (rebuilt from on-chain events on startup)
indexer/events.json

# compiled circuit artifacts (regenerated by `make build`)
dapp/public/circuits/
# vendored prover wasm (ships with @aztec/bb.js + the Noir packages)
dapp/public/*.wasm

# local config and secrets (templates are kept)
.env
.env.*
*.env
!.env.example

# logs / editor / os
*.log
.DS_Store
.vscode/
.idea/
*.swp
