# Relayer ("Carrier") config. Copy to .env and fill it in locally.
# Never commit real secret keys.

RPC_URL=https://soroban-testnet.stellar.org
NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Contracts (printed by the deploy step)
POOL_CONTRACT=
VERIFIER_CONTRACT=
COMPLIANCE_CONTRACT=
ENGINE_DEPOSIT=
ENGINE_TRANSFER=
ENGINE_TRANSFER_BATCH=
ENGINE_WITHDRAW_SMALL=
ENGINE_WITHDRAW_LARGE=

# Assets (XLM SAC is the standard testnet id below; set USDC/EURC for your deployment)
USDC_CONTRACT=
EURC_CONTRACT=
XLM_CONTRACT=CAS3J7GYLGXMF6TDJBBYYSE3HQ6BBSMLNUQ34T6TZMYMW2EVH34XOWMA

# Keys: the account that pays gas and submits, and the pool admin / fee recipient.
# Fill these locally and keep them out of git.
RELAYER_SECRET=
ADMIN_SECRET=

INDEXER_URL=http://localhost:3001
PORT=3002

# Keepalive + self-funding loop (the "Healer"). Tune to your own thresholds.
KEEPALIVE_INTERVAL_HOURS=6
TREASURY_ADDRESS=         # cold wallet for skimmed surplus; leave blank for refuel-only
RELAYER_BUFFER_XLM=50
HEALER_MIN_XLM=20
HEALER_REFUEL_TO_XLM=100
MIN_SWEEP_XLM=50
